{
  "name": "saddlerag",
  "displayName": "SaddleRAG",
  "description": "Documentation RAG for AI coding assistants — indexes docs, serves them via MCP",
  "version": "0.0.1",
  "publisher": "jackalope-technologies",
  "engines": { "vscode": "^1.102.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "saddlerag-sidebar": [
        { "id": "saddleragView", "name": "SaddleRAG", "icon": "$(database)" }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "saddlerag-sidebar",
          "title": "SaddleRAG",
          "icon": "$(database)"
        }
      ]
    },
    "commands": [
      { "command": "saddlerag.refresh", "title": "Refresh", "icon": "$(refresh)" },
      { "command": "saddlerag.openWebHub", "title": "Open Web Hub", "icon": "$(link-external)" }
    ],
    "menus": {
      "view/title": [
        { "command": "saddlerag.refresh", "when": "view == saddleragView", "group": "navigation" },
        { "command": "saddlerag.openWebHub", "when": "view == saddleragView", "group": "navigation" }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "jest",
    "test:integration": "node ./out/test/runTests.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.102.0",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.4.0"
  }
}
