<Application x:Class="SaddleRAG.Tray.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <tb:TaskbarIcon x:Key="TrayIcon"
                        ToolTipText="SaddleRAG MCP"
                        IconSource="/Resources/saddlerag-icon.ico">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="StartItem" Header="Start MCP" Click="OnStart"/>
                    <MenuItem x:Name="StopItem"  Header="Stop MCP"  Click="OnStop"/>
                    <Separator/>
                    <MenuItem Header="Open dashboard" Click="OnOpenDashboard"/>
                    <Separator/>
                    <MenuItem x:Name="InstallMenu"   Header="Install into"/>
                    <MenuItem x:Name="UninstallMenu" Header="Uninstall from"/>
                    <MenuItem Header="Status" Click="OnStatus"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="OnExitClicked"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Application.Resources>
</Application>
