<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

    <Package Name="SaddleRAG MCP Server"
             Manufacturer="Jackalope Technologies, Inc."
             Version="$(var.Version)"
             UpgradeCode="CA600210-74B0-4CDC-90AC-A2798F2136F6"
             Scope="perMachine">

        <MajorUpgrade DowngradeErrorMessage="A newer version of SaddleRAG is already installed."
                      AllowSameVersionUpgrades="yes" />
        <MediaTemplate EmbedCab="yes" />

        <!-- Branding: Add/Remove Programs icon + reusable icon id for the shortcut. -->
        <Icon Id="SaddleRagIcon.ico" SourceFile="..\assets\branding\saddlerag-icon.ico" />
        <Property Id="ARPPRODUCTICON" Value="SaddleRagIcon.ico" />

        <!-- DirectML requires Windows 10 version 1903 (build 18362) or later.    -->
        <!-- CheckGpuCapability CA sets WINDOWSBUILDNUMBER as a numeric property  -->
        <!-- from HKLM\...\CurrentVersion\CurrentBuildNumber before this check    -->
        <!-- fires (scheduled Before="LaunchConditions" in both sequences). The   -->
        <!-- "WINDOWSBUILDNUMBER = 0" branch lets install proceed when the CA     -->
        <!-- couldn't read the registry — the runtime EP-append fallback         -->
        <!-- (OnnxExecutionProviderConfigurator) catches DirectML load failures  -->
        <!-- and degrades to CPU with a recorded warning, so a permissive launch -->
        <!-- gate is safer than blocking a legitimate install on flaky WMI/Reg.  -->
        <!-- "Installed" branch keeps existing installs upgradable.              -->
        <Launch Condition="Installed OR WINDOWSBUILDNUMBER = &quot;0&quot; OR WINDOWSBUILDNUMBER &gt;= 18362"
                Message="SaddleRAG requires Windows 10 version 1903 (build 18362) or later for DirectML support. Please update Windows and try again." />

        <!-- Always emit a verbose Windows Installer log so install/repair/upgrade -->
        <!-- failures are diagnosable without having to remember `msiexec /L*v`. -->
        <!-- Log lands in %TEMP%\MSI*.log; runtime path is exposed in MsiLogFileLocation. -->
        <Property Id="MsiLogging" Value="voicewarmupx!" />

        <!-- User-configurable properties -->
        <Property Id="MONGOCONNECTION" Value="mongodb://localhost:27017" />
        <Property Id="MONGODATABASE" Value="SaddleRAG" />
        <Property Id="OLLAMAENDPOINT" Value="http://localhost:11434" />
        <Property Id="MONGOSTATUS" Secure="yes" />
        <Property Id="MONGOTEST_PASS" Value="0" Secure="yes" />
        <Property Id="OLLAMASTATUS" Secure="yes" />
        <Property Id="OLLAMATEST_PASS" Value="0" Secure="yes" />
        <Property Id="REGISTER_CLAUDE_CODE"    Value="1" Secure="yes" />
        <Property Id="REGISTER_CLAUDE_DESKTOP" Value="1" Secure="yes" />
        <Property Id="REGISTER_VSCODE_MCP"     Value="1" Secure="yes" />
        <Property Id="REGISTER_COPILOT_CLI"    Value="1" Secure="yes" />
        <Property Id="REGISTER_CLAUDE_CODE_ARG" Value="--claude-code=false" Secure="yes" />
        <Property Id="REGISTER_CLAUDE_DESKTOP_ARG" Value="--claude-desktop=false" Secure="yes" />
        <Property Id="REGISTER_VSCODE_MCP_ARG" Value="--vscode-mcp=false" Secure="yes" />
        <Property Id="REGISTER_COPILOT_CLI_ARG" Value="--copilot-cli=false" Secure="yes" />
        <Property Id="REGISTER_CODEX"           Value="1" Secure="yes" />
        <Property Id="REGISTER_CODEX_ARG"       Value="--codex=false" Secure="yes" />

        <!-- Ollama keep-alive detection: CheckOllamaKeepAlive CA populates these -->
        <!-- in the UI sequence so the Ollama dialog can show or hide a notice. -->
        <Property Id="OLLAMA_KEEPALIVE_EXISTING" Secure="yes" />
        <Property Id="OLLAMA_KEEPALIVE_WILL_SET" Value="0" Secure="yes" />
        <Property Id="OLLAMA_KEEPALIVE_NOTICE" Secure="yes" />

        <!-- GPU detection: CheckGpuCapability CA populates these before    -->
        <!-- LaunchConditions in both sequences. WINDOWSBUILDNUMBER gates   -->
        <!-- the launch condition; GPU_DETECTED + GPU_DETECTION_REASON      -->
        <!-- drive ExecutionModeDlg's radio default and helper text.        -->
        <!-- ONNX_EXECUTION_PROVIDER is intentionally declared without a    -->
        <!-- Value attribute so "empty means auto-detect" is unambiguous.   -->
        <!-- The CA only writes ONNX_EXECUTION_PROVIDER when empty, which   -->
        <!-- preserves either a silent-install command-line value or, on    -->
        <!-- interactive installs, the user's RadioButtonGroup click across -->
        <!-- the Execute-sequence re-run. See the empty-guard block in      -->
        <!-- CheckGpuCapability.js for the full rationale.                  -->
        <Property Id="WINDOWSBUILDNUMBER" Value="0" Secure="yes" />
        <Property Id="GPU_DETECTED" Value="0" Secure="yes" />
        <Property Id="GPU_DETECTION_REASON" Secure="yes" />
        <Property Id="ONNX_EXECUTION_PROVIDER" Secure="yes" />

        <!-- Escaped variants of the four PatchAppSettings inputs, written by  -->
        <!-- EscapeAppSettingsProperties so a literal " in a Mongo password or -->
        <!-- Ollama URL doesn't break the powershell.exe argv parse before    -->
        <!-- the .ps1 can record the failure. See EscapeAppSettingsProperties.js -->
        <!-- for the escape rules.                                            -->
        <Property Id="MONGOCONNECTION_ESCAPED" Secure="yes" />
        <Property Id="MONGODATABASE_ESCAPED" Secure="yes" />
        <Property Id="OLLAMAENDPOINT_ESCAPED" Secure="yes" />
        <Property Id="ONNX_EXECUTION_PROVIDER_ESCAPED" Secure="yes" />

        <!-- Set by EscapeAppSettingsProperties.js when a per-property escape  -->
        <!-- throws. PatchAppSettings.ps1 reads this and aborts if non-empty   -->
        <!-- so the install doesn't silently write empty Mongo / Ollama values -->
        <!-- when the upstream escape blew up. Declared without a Value so     -->
        <!-- the "empty == nothing failed" semantic is unambiguous.            -->
        <Property Id="ESCAPE_FAILED" Secure="yes" />

        <!-- Directories -->
        <StandardDirectory Id="ProgramFiles64Folder">
            <Directory Id="MCPFOLDER" Name="SaddleRAG.Mcp" />
        </StandardDirectory>

        <!-- Published files -->
        <ComponentGroup Id="PublishOutput" Directory="MCPFOLDER">
            <Files Include="$(var.PublishDir)\**" />
        </ComponentGroup>

        <!-- Windows service -->
        <Component Id="ServiceComponent" Directory="MCPFOLDER" Guid="E697864C-7E01-457A-A2BA-0F0C655D64F2">
            <ServiceInstall Id="SaddleRAGMcpService"
                            Type="ownProcess"
                            Name="SaddleRAGMcp"
                            DisplayName="SaddleRAG MCP Server"
                            Description="Documentation RAG system - MCP server for AI-assisted code documentation lookup."
                            Start="auto"
                            ErrorControl="normal"
                            Account="LocalSystem" />
            <!--
                The per-user service-control ACL grant (so the non-elevated tray can
                start/stop the service without UAC) is applied by start-and-monitor.ps1
                (Add-UsersServiceControlAce), NOT by a util:PermissionEx here.

                Why: in practice MSI's standard InstallServices (seq 5800) does not
                create this service - ServiceComponent has no keypath exe (the binary is
                harvested into PublishOutput), so InstallServices emits no create op.
                start-and-monitor.ps1 registers the service via New-Service at the
                StartAndMonitorService CA (seq 5899). A util:PermissionEx compiles to
                Wix4ExecSecureObjects (seq 5801), which runs ~94 slots BEFORE the
                service exists and fails fatally with 0x80070424
                ERROR_SERVICE_DOES_NOT_EXIST, rolling the whole install back. Granting
                in the PS1 - immediately after New-Service - keeps the ACE
                (A;;RPWPLORC;;;BU) in lockstep with service creation. -->

            <!-- ServiceControl drives stop-on-install/uninstall and removal on uninstall. -->
            <!-- Our StartAndMonitorService CA (which also registers the service via New-Service) -->
            <!-- runs BEFORE MSI's standard StartServices, drives the service to Running with -->
            <!-- retries (since cold .NET startup can trip SCM's 30s pre-dispatcher gate), and -->
            <!-- gates install success on a /health 200. By the time MSI's StartServices fires, -->
            <!-- the service is already Running, so it's a no-op pass. -->
            <ServiceControl Id="StartSaddleRAGMcp"
                            Name="SaddleRAGMcp"
                            Start="install"
                            Stop="both"
                            Remove="uninstall"
                            Wait="yes" />
        </Component>

        <!-- Tray autostart (per-machine Run key) + Start Menu shortcut. The tray is
             independent of the service: login launches it; it talks to SCM + /health.
             SaddleRAG.Tray.exe is already harvested by PublishOutput, so no <File> here. -->
        <Component Id="TrayAutostartComponent" Directory="MCPFOLDER" Guid="2C9F1E54-9C0B-4E2E-9E2E-7B7A1A6F0C31">
            <RegistryValue Root="HKLM"
                           Key="Software\Microsoft\Windows\CurrentVersion\Run"
                           Name="SaddleRAGTray"
                           Type="string"
                           Value="&quot;[MCPFOLDER]SaddleRAG.Tray.exe&quot;"
                           KeyPath="yes" />
        </Component>

        <!-- Close a running tray on uninstall/upgrade so its exe isn't locked and
             no orphan icon remains after the service + files go away. Top-level
             element: schedules the WixCloseApplications CA. -->
        <util:CloseApplication Id="CloseSaddleRagTray"
                               Target="SaddleRAG.Tray.exe"
                               CloseMessage="yes"
                               RebootPrompt="no"
                               EndSessionMessage="yes" />

        <!-- Start Menu shortcut so users can relaunch the tray if they exit it. -->
        <StandardDirectory Id="ProgramMenuFolder">
            <Directory Id="SaddleRagMenuDir" Name="SaddleRAG" />
        </StandardDirectory>

        <Component Id="TrayShortcutComponent" Directory="SaddleRagMenuDir" Guid="7E3D2B19-44F1-4B0C-8C2A-9D6F5E2B1A77">
            <Shortcut Id="TrayStartMenuShortcut"
                      Name="SaddleRAG Tray"
                      Description="Start/stop the SaddleRAG MCP service and install AI helpers"
                      Target="[MCPFOLDER]SaddleRAG.Tray.exe"
                      Icon="SaddleRagIcon.ico"
                      WorkingDirectory="MCPFOLDER" />
            <RemoveFolder Id="RemoveSaddleRagMenuDir" Directory="SaddleRagMenuDir" On="uninstall" />
            <!-- KeyPath in HKLM (not HKCU): this is a perMachine package whose install runs
                 as LocalSystem. An HKCU keypath would land in HKU\.DEFAULT and make the
                 component look absent at uninstall, orphaning the Start Menu folder. -->
            <RegistryValue Root="HKLM" Key="Software\Jackalope Technologies\SaddleRAG\Tray"
                           Name="ShortcutInstalled" Type="integer" Value="1" KeyPath="yes" />
        </Component>

        <!-- Helper scripts installed to MCPFOLDER so SetProperty can reference them  -->
        <!-- via -File "[MCPFOLDER]Script.ps1" without any inline PowerShell that    -->
        <!-- would be mangled by MSI's property formatter eating [...] expressions.  -->
        <Component Id="HelperScripts" Directory="MCPFOLDER" Guid="B3A1F2E4-9C7D-4E8B-A5F1-2D3E4F5A6B7C">
            <File Source="SetOllamaKeepAlive.ps1" />
            <File Source="UnsetOllamaKeepAlive.ps1" />
            <File Source="PatchAppSettings.ps1" />
            <File Source="ConfigureCrashCapture.ps1" />
            <File Source="RemoveCrashCapture.ps1" />
        </Component>

        <Feature Id="Main" Title="SaddleRAG MCP Server" Level="1">
            <ComponentGroupRef Id="PublishOutput" />
            <ComponentRef Id="ServiceComponent" />
            <ComponentRef Id="HelperScripts" />
            <ComponentRef Id="TrayAutostartComponent" />
            <ComponentRef Id="TrayShortcutComponent" />
        </Feature>

        <!-- Test MongoDB connection (JScript CA, runs during UI).                      -->
        <!-- Parses MONGOCONNECTION to extract host/port, writes a temp PowerShell    -->
        <!-- script, runs it synchronously, reads the result, and sets MONGOSTATUS.   -->
        <!-- Return=ignore so no MSI error dialog ever fires on failure.              -->
        <CustomAction Id="TestMongoConnection"
                      Script="jscript"
                      ScriptSourceFile="TestMongoConnection.js"
                      Execute="immediate"
                      Return="ignore" />

        <!-- Test Ollama connection (JScript CA, runs during UI).                     -->
        <!-- Uses MSXML2.ServerXMLHTTP for a direct HTTP GET against the endpoint.   -->
        <!-- Return=ignore so no MSI error dialog ever fires on failure.             -->
        <CustomAction Id="TestOllamaConnection"
                      Script="jscript"
                      ScriptSourceFile="TestOllamaConnection.js"
                      Execute="immediate"
                      Return="ignore" />

        <!-- Open download pages in the default browser via WScript.Shell.Run.        -->
        <!-- Uses the URL directly so no WIXSHELLEXECTARGET property is needed.      -->
        <CustomAction Id="LaunchMongoDownload"
                      Script="jscript"
                      ScriptSourceFile="LaunchMongoDownload.js"
                      Execute="immediate"
                      Return="ignore" />

        <CustomAction Id="LaunchOllamaDownload"
                      Script="jscript"
                      ScriptSourceFile="LaunchOllamaDownload.js"
                      Execute="immediate"
                      Return="ignore" />

        <!-- UI-time CA: read system OLLAMA_KEEP_ALIVE so the Ollama dialog can -->
        <!-- decide whether to show the "we will set OLLAMA_KEEP_ALIVE=-1" notice. -->
        <!-- Sets properties OLLAMA_KEEPALIVE_EXISTING and OLLAMA_KEEPALIVE_WILL_SET. -->
        <CustomAction Id="CheckOllamaKeepAlive"
                      Script="jscript"
                      ScriptSourceFile="CheckOllamaKeepAlive.js"
                      Execute="immediate"
                      Return="ignore" />

        <!-- Detect GPU/DirectML capability so ExecutionModeDlg can pre-select the -->
        <!-- right radio and silent installs default sensibly. Also reads OS build -->
        <!-- number so the <Launch> condition above can block on Windows < 18362.  -->
        <!-- Sequencing and the Return="ignore" rationale are documented on the    -->
        <!-- <Launch> element; this CA inherits both.                              -->
        <CustomAction Id="CheckGpuCapability"
                      Script="jscript"
                      ScriptSourceFile="CheckGpuCapability.js"
                      Execute="immediate"
                      Return="ignore" />

        <!-- Pre-escape the four PatchAppSettings inputs so a literal " in any   -->
        <!-- value (Mongo password with a quote, Ollama URL containing one) doesn't -->
        <!-- terminate the powershell.exe argv parse before the .ps1's try/catch  -->
        <!-- can record the failure. Runs in the Execute sequence right before     -->
        <!-- PatchAppSettings.                                                    -->
        <CustomAction Id="EscapeAppSettingsProperties"
                      Script="jscript"
                      ScriptSourceFile="EscapeAppSettingsProperties.js"
                      Execute="immediate"
                      Return="ignore" />

        <!-- Patch appsettings.json with user-provided values (deferred, after file install).  -->
        <!-- Delegates to PatchAppSettings.ps1 installed under MCPFOLDER so the logic is unit-  -->
        <!-- testable (see SaddleRAG.Tests/Installer/PatchAppSettingsTests.cs) and isolated     -->
        <!-- from MSI property-formatting quirks. CA is Return="ignore" so a script failure     -->
        <!-- lands in the verbose MSI log without aborting the install; the runtime EP         -->
        <!-- fallback in OnnxExecutionProviderConfigurator absorbs a missing/wrong              -->
        <!-- ExecutionProvider write, and a missing Mongo/Ollama write fails visibly at        -->
        <!-- startup config-binding rather than silently committing a broken install.          -->
        <SetProperty Id="PatchAppSettings"
                     Before="PatchAppSettings"
                     Sequence="execute"
                     Value="&quot;powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[MCPFOLDER]PatchAppSettings.ps1&quot; -AppSettingsPath &quot;[MCPFOLDER]appsettings.json&quot; -ConnectionString &quot;[MONGOCONNECTION_ESCAPED]&quot; -DatabaseName &quot;[MONGODATABASE_ESCAPED]&quot; -OllamaEndpoint &quot;[OLLAMAENDPOINT_ESCAPED]&quot; -ExecutionProvider &quot;[ONNX_EXECUTION_PROVIDER_ESCAPED]&quot; -EscapeFailed &quot;[ESCAPE_FAILED]&quot;" />

        <CustomAction Id="PatchAppSettings"
                      BinaryRef="Wix4UtilCA_X86"
                      DllEntry="WixQuietExec"
                      Execute="deferred"
                      Return="ignore"
                      Impersonate="no" />

        <!-- Register SaddleRAG with selected AI tools via the SaddleRAG.Cli subcommand. -->
        <!-- Impersonate="yes" so $USERPROFILE / $APPDATA resolve to the installing user. -->
        <SetProperty Id="REGISTER_CLAUDE_CODE_ARG"
                 Before="RegisterAiClients"
                 Sequence="execute"
                 Value="--claude-code=true"
                 Condition="REGISTER_CLAUDE_CODE = &quot;1&quot;" />

        <SetProperty Id="REGISTER_CLAUDE_DESKTOP_ARG"
                 Before="RegisterAiClients"
                 Sequence="execute"
                 Value="--claude-desktop=true"
                 Condition="REGISTER_CLAUDE_DESKTOP = &quot;1&quot;" />

        <SetProperty Id="REGISTER_VSCODE_MCP_ARG"
                 Before="RegisterAiClients"
                 Sequence="execute"
                 Value="--vscode-mcp=true"
                 Condition="REGISTER_VSCODE_MCP = &quot;1&quot;" />

        <SetProperty Id="REGISTER_COPILOT_CLI_ARG"
                 Before="RegisterAiClients"
                 Sequence="execute"
                 Value="--copilot-cli=true"
                 Condition="REGISTER_COPILOT_CLI = &quot;1&quot;" />

        <SetProperty Id="REGISTER_CODEX_ARG"
                 Before="RegisterAiClients"
                 Sequence="execute"
                 Value="--codex=true"
                 Condition="REGISTER_CODEX = &quot;1&quot;" />

        <!-- Unattended, best-effort registration: the detected-only flag registers only -->
        <!-- the agents whose config/CLI is actually present on the machine and silently  -->
        <!-- skips the rest (missing => skipped, exit 0, never fatal). It deliberately    -->
        <!-- ignores the per-agent [REGISTER_*_ARG] flags built above (see                -->
        <!-- RegisterClientsCommand.cs), so those SetProperty actions are inert here and  -->
        <!-- the AiClientsDlg checkboxes no longer gate registration; detection does.     -->
        <!-- Routed through cmd /c so %TEMP% is expanded at runtime in the impersonated -->
        <!-- user's context. WixQuietExec CreateProcess-es the target directly and does  -->
        <!-- NOT expand environment variables, so a bare %TEMP% reaches the CLI as a     -->
        <!-- literal and crashes it with DirectoryNotFoundException (the CA's CWD is     -->
        <!-- SysWOW64). [%ComSpec] resolves to cmd.exe at install time.                  -->
        <SetProperty Id="RegisterAiClients"
                     Before="RegisterAiClients"
                     Sequence="execute"
                 Value="&quot;[%ComSpec]&quot; /c &quot;&quot;[MCPFOLDER]SaddleRAG.Cli.exe&quot; register-clients --detected-only --quiet --log-file &quot;%TEMP%\SaddleRAG-register.log&quot;&quot;" />

        <CustomAction Id="RegisterAiClients"
                      BinaryRef="Wix4UtilCA_X86"
                      DllEntry="WixQuietExec"
                      Execute="deferred"
                      Return="ignore"
                      Impersonate="yes" />

        <!-- Unregister SaddleRAG from all nine AI tools on uninstall. With no per-agent  -->
        <!-- flags, unregister-clients targets the full set (claude-code, claude-desktop, -->
        <!-- vscode-mcp, copilot-cli, codex, cursor, gemini-cli, windsurf, visual-studio);-->
        <!-- per-tool selection at install time does not affect uninstall. Return=ignore  -->
        <!-- keeps it best-effort so a missing/locked config never blocks uninstall.      -->
        <!-- cmd /c wrapper: see RegisterAiClients above (runtime %TEMP% expansion). -->
        <SetProperty Id="UnregisterAiClients"
                     Before="UnregisterAiClients"
                     Sequence="execute"
                     Value="&quot;[%ComSpec]&quot; /c &quot;&quot;[MCPFOLDER]SaddleRAG.Cli.exe&quot; unregister-clients --quiet --log-file &quot;%TEMP%\SaddleRAG-unregister.log&quot;&quot;" />

        <CustomAction Id="UnregisterAiClients"
                      BinaryRef="Wix4UtilCA_X86"
                      DllEntry="WixQuietExec"
                      Execute="deferred"
                      Return="ignore"
                      Impersonate="yes" />

        <!-- Set OLLAMA_KEEP_ALIVE=-1 system-wide on install, but only if it isn't -->
        <!-- already set. The script writes a registry marker so uninstall knows -->
        <!-- whether we set it. Impersonate="no" so it runs elevated and can -->
        <!-- write to the Machine env scope. -->
        <SetProperty Id="SetOllamaKeepAlive"
                     Before="SetOllamaKeepAlive"
                     Sequence="execute"
                     Value="&quot;powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[MCPFOLDER]SetOllamaKeepAlive.ps1&quot;" />

        <CustomAction Id="SetOllamaKeepAlive"
                      BinaryRef="Wix4UtilCA_X86"
                      DllEntry="WixQuietExec"
                      Execute="deferred"
                      Return="ignore"
                      Impersonate="no" />

        <!-- Conditionally remove OLLAMA_KEEP_ALIVE on uninstall. Removes only if -->
        <!-- our marker is present AND the current value still matches what we set, -->
        <!-- so user changes after install are respected. Always cleans up the -->
        <!-- marker registry key so we don't leave breadcrumbs. -->
        <SetProperty Id="UnsetOllamaKeepAlive"
                     Before="UnsetOllamaKeepAlive"
                     Sequence="execute"
                     Value="&quot;powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[MCPFOLDER]UnsetOllamaKeepAlive.ps1&quot;" />

        <CustomAction Id="UnsetOllamaKeepAlive"
                      BinaryRef="Wix4UtilCA_X86"
                      DllEntry="WixQuietExec"
                      Execute="deferred"
                      Return="ignore"
                      Impersonate="no" />

        <!-- Configure WER LocalDumps for SaddleRAG.Mcp.exe so native crashes -->
        <!-- (e.g. the ONNX access violation in issue #135) leave a full dump -->
        <!-- under %ProgramData%\SaddleRAG\CrashDumps for post-mortems (#136). -->
        <!-- Impersonate="no": writes HKLM, must run elevated. -->
        <SetProperty Id="ConfigureCrashCapture"
                     Before="ConfigureCrashCapture"
                     Sequence="execute"
                     Value="&quot;powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[MCPFOLDER]ConfigureCrashCapture.ps1&quot;" />

        <CustomAction Id="ConfigureCrashCapture"
                      BinaryRef="Wix4UtilCA_X86"
                      DllEntry="WixQuietExec"
                      Execute="deferred"
                      Return="ignore"
                      Impersonate="no" />

        <!-- Remove the LocalDumps registry configuration on uninstall. Captured -->
        <!-- dumps are intentionally left on disk for post-uninstall forensics. -->
        <SetProperty Id="RemoveCrashCapture"
                     Before="RemoveCrashCapture"
                     Sequence="execute"
                     Value="&quot;powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[MCPFOLDER]RemoveCrashCapture.ps1&quot;" />

        <CustomAction Id="RemoveCrashCapture"
                      BinaryRef="Wix4UtilCA_X86"
                      DllEntry="WixQuietExec"
                      Execute="deferred"
                      Return="ignore"
                      Impersonate="no" />

        <!-- Prewarm OS file cache + validate the binary by running it once with the prewarm flag. -->
        <!-- This forces all 215 MB of self-contained runtime into the page cache so SCM's 30s start -->
        <!-- timeout doesn't kill the service on first cold-disk launch. Return is "check" so a real -->
        <!-- binary failure (bad config, DI build error) fails the install fast. -->
        <SetProperty Id="PrewarmService"
                     Before="PrewarmService"
                     Sequence="execute"
                     Value="&quot;[MCPFOLDER]SaddleRAG.Mcp.exe&quot; --prewarm" />

        <CustomAction Id="PrewarmService"
                      BinaryRef="Wix4UtilCA_X86"
                      DllEntry="WixQuietExec"
                      Execute="deferred"
                      Return="check"
                      Impersonate="no" />

        <!-- Replacement for MSI's standard StartServices action: drives the start ourselves -->
        <!-- with a retry+health-poll loop, since SCM's pre-dispatcher 30s gate (ServicesPipeTimeout) -->
        <!-- can be tripped by cold .NET startup of the 215 MB self-contained service. We can't extend -->
        <!-- that gate from inside .NET (it's per-process and fires before our managed code can pump -->
        <!-- SetServiceStatus), so we accept that the FIRST start may fail and retry. The CA returns -->
        <!-- non-zero on persistent failure so MSI rolls back cleanly rather than committing a -->
        <!-- half-installed product where the service never actually runs. -->
        <SetProperty Id="StartAndMonitorService"
                     Before="StartAndMonitorService"
                     Sequence="execute"
                     Value="&quot;powershell.exe&quot; -NoProfile -ExecutionPolicy Bypass -File &quot;[MCPFOLDER]start-and-monitor.ps1&quot; -ServiceName SaddleRAGMcp -HealthUrl http://localhost:6100/health -BinaryPath &quot;[MCPFOLDER]SaddleRAG.Mcp.exe&quot; -TotalTimeoutSec 300" />

        <CustomAction Id="StartAndMonitorService"
                      BinaryRef="Wix4UtilCA_X86"
                      DllEntry="WixQuietExec"
                      Execute="deferred"
                      Return="check"
                      Impersonate="no" />

        <!-- Launch the tray once immediately after a fresh install so the user gets the -->
        <!-- status icon without waiting for the next logon. Fire-and-forget: asyncNoWait -->
        <!-- never waits on or fails from the launch. Runs impersonated so the icon appears -->
        <!-- in the installing user's session. The HKLM Run key handles subsequent logons. -->
        <CustomAction Id="LaunchTray"
                      Directory="MCPFOLDER"
                      ExeCommand="&quot;[MCPFOLDER]SaddleRAG.Tray.exe&quot;"
                      Execute="immediate"
                      Impersonate="yes"
                      Return="asyncNoWait" />

        <InstallExecuteSequence>
            <!-- Must precede LaunchConditions: the launch gate reads -->
            <!-- WINDOWSBUILDNUMBER that this CA populates.            -->
            <Custom Action="CheckGpuCapability" Before="LaunchConditions" />
            <!-- Must precede PatchAppSettings: the SetProperty Value below  -->
            <!-- substitutes the _ESCAPED variants of MONGOCONNECTION etc.   -->
            <Custom Action="EscapeAppSettingsProperties" Before="PatchAppSettings" Condition="NOT Installed OR REINSTALL" />
            <Custom Action="PatchAppSettings" After="InstallFiles" Condition="NOT Installed OR REINSTALL" />
            <Custom Action="RegisterAiClients" After="PatchAppSettings" Condition="NOT Installed OR REINSTALL" />
            <Custom Action="SetOllamaKeepAlive" After="RegisterAiClients" Condition="NOT Installed OR REINSTALL" />
            <Custom Action="ConfigureCrashCapture" After="SetOllamaKeepAlive" Condition="NOT Installed OR REINSTALL" />
            <Custom Action="RemoveCrashCapture" Before="UnsetOllamaKeepAlive" Condition="REMOVE = &quot;ALL&quot;" />
            <Custom Action="UnsetOllamaKeepAlive" Before="UnregisterAiClients" Condition="REMOVE = &quot;ALL&quot;" />
            <Custom Action="UnregisterAiClients" Before="RemoveFiles" Condition="REMOVE = &quot;ALL&quot;" />
            <Custom Action="PrewarmService" Before="StartAndMonitorService" Condition="NOT Installed OR REINSTALL" />
            <Custom Action="StartAndMonitorService" Before="StartServices" Condition="NOT Installed OR REINSTALL" />
            <!-- Immediate exe CA must run after files are committed to disk; there is no -->
            <!-- service-start action to anchor to, so use InstallFinalize. Fresh install -->
            <!-- only (NOT Installed) so repairs/upgrades don't spawn an extra tray; the   -->
            <!-- HKLM Run key + CloseApplication handle those paths. -->
            <Custom Action="LaunchTray" After="InstallFinalize" Condition="NOT Installed" />
        </InstallExecuteSequence>

        <!-- Run CheckOllamaKeepAlive in the UI sequence so the Ollama dialog -->
        <!-- can hide its keep-alive notice when the user already has a value. -->
        <!-- CheckGpuCapability must precede LaunchConditions for the build-  -->
        <!-- number gate, and its property writes (GPU_DETECTED,              -->
        <!-- GPU_DETECTION_REASON, ONNX_EXECUTION_PROVIDER) feed              -->
        <!-- ExecutionModeDlg later in the UI flow.                           -->
        <InstallUISequence>
            <Custom Action="CheckGpuCapability" Before="LaunchConditions" />
            <Custom Action="CheckOllamaKeepAlive" After="CostFinalize" />
        </InstallUISequence>

        <!-- UI -->
        <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="MCPFOLDER" />
        <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />

        <UI>
            <!-- Standard InstallFiles ProgressText never substituted Field 1/9/6 in -->
            <!-- our package, so the dialog always read literally "File: [1], Directory: -->
            <!-- [9], Size: [6]". Override with a static message; the progress bar still -->
            <!-- advances normally. -->
            <ProgressText Action="InstallFiles" Message="Copying new files..." />
            <ProgressText Action="RemoveFiles" Message="Removing files..." />
            <ProgressText Action="InstallServices" Message="Registering Windows service..." />
            <ProgressText Action="StartServices" Message="Starting Windows service..." />
            <ProgressText Action="StopServices" Message="Stopping Windows service..." />
            <ProgressText Action="DeleteServices" Message="Removing Windows service..." />
            <ProgressText Action="PatchAppSettings" Message="Writing configuration..." />
            <ProgressText Action="RegisterAiClients" Message="Registering AI tool integrations..." />
            <ProgressText Action="UnregisterAiClients" Message="Removing AI tool integrations..." />
            <ProgressText Action="SetOllamaKeepAlive" Message="Configuring Ollama keep-alive..." />
            <ProgressText Action="UnsetOllamaKeepAlive" Message="Removing Ollama keep-alive setting..." />
            <ProgressText Action="ConfigureCrashCapture" Message="Configuring crash dump capture..." />
            <ProgressText Action="RemoveCrashCapture" Message="Removing crash dump configuration..." />
            <ProgressText Action="PrewarmService" Message="Warming up runtime, please wait (this takes 15-30 seconds)..." />
            <ProgressText Action="StartAndMonitorService" Message="Starting SaddleRAG service..." />

            <!-- MongoDB configuration dialog -->
            <Dialog Id="MongoDbDlg" Width="370" Height="270" Title="MongoDB Configuration">
                <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
                <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

                <Control Id="Title" Type="Text" X="20" Y="10" Width="290" Height="14"
                         Transparent="yes" NoPrefix="yes"
                         Text="{\WixUI_Font_Title}MongoDB Connection" />

                <Control Id="Description" Type="Text" X="25" Y="55" Width="320" Height="35"
                         Transparent="yes" NoPrefix="yes"
                         Text="SaddleRAG stores documentation in MongoDB. If running locally on this machine, the default connection (port 27017) will work. Otherwise, enter your MongoDB connection string." />

                <Control Id="ConnLabel" Type="Text" X="25" Y="98" Width="320" Height="12"
                         Text="Connection String:" />
                <Control Id="ConnEdit" Type="Edit" X="25" Y="112" Width="320" Height="18"
                         Property="MONGOCONNECTION" />

                <Control Id="DbLabel" Type="Text" X="25" Y="140" Width="320" Height="12"
                         Text="Database Name:" />
                <Control Id="DbEdit" Type="Edit" X="25" Y="154" Width="200" Height="18"
                         Property="MONGODATABASE" />

                <Control Id="ResetBtn" Type="PushButton" X="25" Y="182" Width="100" Height="17"
                         Text="Reset to Local">
                    <Publish Property="MONGOCONNECTION" Value="mongodb://localhost:27017" />
                    <Publish Property="MONGODATABASE" Value="SaddleRAG" />
                    <Publish Property="MONGOSTATUS" Value=" " />
                </Control>

                <Control Id="TestBtn" Type="PushButton" X="135" Y="182" Width="100" Height="17"
                         Text="Test Connection">
                    <Publish Property="MONGOSTATUS" Value="Testing..." Order="1" />
                    <Publish Event="DoAction" Value="TestMongoConnection" Order="2" />
                    <Publish Property="MONGOSTATUS" Value="Connected!" Order="3" Condition="MONGOTEST_PASS = &quot;1&quot;" />
                    <Publish Property="MONGOSTATUS" Value="Failed: cannot connect" Order="4" Condition="MONGOTEST_PASS = &quot;0&quot;" />
                </Control>

                <Control Id="DownloadBtn" Type="PushButton" X="245" Y="182" Width="100" Height="17"
                         Text="Download MongoDB">
                    <Publish Property="MONGOSTATUS" Value="Opening browser..." Order="1" />
                    <Publish Event="DoAction" Value="LaunchMongoDownload" Order="2" />
                    <Publish Property="MONGOSTATUS" Value=" " Order="3" />
                </Control>

                <Control Id="StatusText" Type="Edit" X="25" Y="204" Width="320" Height="18"
                         Disabled="yes" Property="MONGOSTATUS" />

                <Control Id="BottomLine" Type="Line" X="0" Y="228" Width="370" Height="0" />
                <Control Id="Back" Type="PushButton" X="180" Y="247" Width="56" Height="17" Text="&amp;Back">
                    <Publish Event="NewDialog" Value="InstallDirDlg" />
                </Control>
                <Control Id="Next" Type="PushButton" X="236" Y="247" Width="56" Height="17" Default="yes" Text="&amp;Next">
                    <Publish Event="NewDialog" Value="OllamaDlg" />
                </Control>
                <Control Id="Cancel" Type="PushButton" X="304" Y="247" Width="56" Height="17" Cancel="yes" Text="Cancel">
                    <Publish Event="SpawnDialog" Value="CancelDlg" />
                </Control>
            </Dialog>

            <!-- Ollama configuration dialog -->
            <Dialog Id="OllamaDlg" Width="370" Height="270" Title="Ollama Configuration">
                <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
                <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

                <Control Id="Title" Type="Text" X="20" Y="10" Width="290" Height="14"
                         Transparent="yes" NoPrefix="yes"
                         Text="{\WixUI_Font_Title}Ollama AI Engine" />

                <Control Id="Description" Type="Text" X="25" Y="55" Width="320" Height="35"
                         Transparent="yes" NoPrefix="yes"
                         Text="SaddleRAG uses Ollama for document embeddings and classification. Ollama should be installed and running on this machine. Required AI models are pulled automatically on first use." />

                <Control Id="EndpointLabel" Type="Text" X="25" Y="98" Width="320" Height="12"
                         Text="Ollama Endpoint:" />
                <Control Id="EndpointEdit" Type="Edit" X="25" Y="112" Width="320" Height="18"
                         Property="OLLAMAENDPOINT" />

                <Control Id="ResetBtn" Type="PushButton" X="25" Y="142" Width="100" Height="17"
                         Text="Reset to Local">
                    <Publish Property="OLLAMAENDPOINT" Value="http://localhost:11434" />
                    <Publish Property="OLLAMASTATUS" Value=" " />
                </Control>

                <Control Id="TestBtn" Type="PushButton" X="135" Y="142" Width="100" Height="17"
                         Text="Test Connection">
                    <Publish Property="OLLAMASTATUS" Value="Testing..." Order="1" />
                    <Publish Event="DoAction" Value="TestOllamaConnection" Order="2" />
                    <Publish Property="OLLAMASTATUS" Value="Connected - Ollama is running" Order="3" Condition="OLLAMATEST_PASS = &quot;1&quot;" />
                    <Publish Property="OLLAMASTATUS" Value="Failed: cannot reach endpoint" Order="4" Condition="OLLAMATEST_PASS = &quot;0&quot;" />
                </Control>

                <Control Id="DownloadBtn" Type="PushButton" X="245" Y="142" Width="100" Height="17"
                         Text="Download Ollama">
                    <Publish Property="OLLAMASTATUS" Value="Opening browser..." Order="1" />
                    <Publish Event="DoAction" Value="LaunchOllamaDownload" Order="2" />
                    <Publish Property="OLLAMASTATUS" Value=" " Order="3" />
                </Control>

                <Control Id="StatusText" Type="Edit" X="25" Y="164" Width="320" Height="18"
                         Disabled="yes" Property="OLLAMASTATUS" />

                <Control Id="InfoText" Type="Text" X="25" Y="188" Width="320" Height="14"
                         Transparent="yes" NoPrefix="yes"
                         Text="Don't have Ollama? Download it for free from https://ollama.com." />

                <!-- Keep-alive notice. Text comes from the OLLAMA_KEEPALIVE_NOTICE -->
                <!-- property, which CheckOllamaKeepAlive populates with either   -->
                <!-- the message or an empty string. WiX 5 does not allow show/   -->
                <!-- hide Conditions as child elements of Control, so we toggle   -->
                <!-- visibility by toggling the rendered text instead.            -->
                <Control Id="KeepAliveText" Type="Text" X="25" Y="204" Width="320" Height="22"
                         Transparent="yes" NoPrefix="yes"
                         Text="[OLLAMA_KEEPALIVE_NOTICE]" />

                <Control Id="BottomLine" Type="Line" X="0" Y="228" Width="370" Height="0" />
                <Control Id="Back" Type="PushButton" X="180" Y="247" Width="56" Height="17" Text="&amp;Back">
                    <Publish Event="NewDialog" Value="MongoDbDlg" />
                </Control>
                <Control Id="Next" Type="PushButton" X="236" Y="247" Width="56" Height="17" Default="yes" Text="&amp;Next">
                    <Publish Event="NewDialog" Value="ExecutionModeDlg" />
                </Control>
                <Control Id="Cancel" Type="PushButton" X="304" Y="247" Width="56" Height="17" Cancel="yes" Text="Cancel">
                    <Publish Event="SpawnDialog" Value="CancelDlg" />
                </Control>
            </Dialog>

            <!-- ONNX execution-mode dialog. RadioButtonGroup reads/writes        -->
            <!-- ONNX_EXECUTION_PROVIDER, which CheckGpuCapability seeded with    -->
            <!-- "DirectMl" or "Cpu" based on WMI detection. GPU_DETECTION_REASON -->
            <!-- is rendered verbatim as helper text so the user knows what was   -->
            <!-- (or wasn't) detected and can override if needed.                 -->
            <Dialog Id="ExecutionModeDlg" Width="370" Height="270" Title="Execution Mode">
                <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
                <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

                <Control Id="Title" Type="Text" X="20" Y="10" Width="290" Height="14"
                         Transparent="yes" NoPrefix="yes"
                         Text="{\WixUI_Font_Title}Execution Mode" />

                <Control Id="Description" Type="Text" X="25" Y="55" Width="320" Height="35"
                         Transparent="yes" NoPrefix="yes"
                         Text="SaddleRAG can run the embedding and reranker models on the CPU or on a DirectX 12 GPU via DirectML. GPU is typically 5-20x faster for search queries. Choose CPU if you'd rather not use a GPU on this machine." />

                <Control Id="ModeGroup" Type="RadioButtonGroup" X="25" Y="100" Width="320" Height="40"
                         Property="ONNX_EXECUTION_PROVIDER">
                    <RadioButtonGroup Property="ONNX_EXECUTION_PROVIDER">
                        <RadioButton Value="DirectMl" X="0" Y="0"  Width="320" Height="17"
                                     Text="GPU (DirectML) - recommended when a DirectX 12 GPU is present" />
                        <RadioButton Value="Cpu"      X="0" Y="20" Width="320" Height="17"
                                     Text="CPU - works everywhere, slower" />
                    </RadioButtonGroup>
                </Control>

                <Control Id="DetectionLabel" Type="Text" X="25" Y="150" Width="320" Height="12"
                         Transparent="yes" NoPrefix="yes" Text="Detection result:" />
                <Control Id="DetectionText" Type="Text" X="25" Y="164" Width="320" Height="40"
                         Transparent="yes" NoPrefix="yes"
                         Text="[GPU_DETECTION_REASON]" />

                <Control Id="InfoText" Type="Text" X="25" Y="206" Width="320" Height="20"
                         Transparent="yes" NoPrefix="yes"
                         Text="You can switch later with the set_execution_provider MCP tool; no reinstall required." />

                <Control Id="BottomLine" Type="Line" X="0" Y="228" Width="370" Height="0" />
                <Control Id="Back" Type="PushButton" X="180" Y="247" Width="56" Height="17" Text="&amp;Back">
                    <Publish Event="NewDialog" Value="OllamaDlg" />
                </Control>
                <Control Id="Next" Type="PushButton" X="236" Y="247" Width="56" Height="17" Default="yes" Text="&amp;Next">
                    <Publish Event="NewDialog" Value="AiClientsDlg" />
                </Control>
                <Control Id="Cancel" Type="PushButton" X="304" Y="247" Width="56" Height="17" Cancel="yes" Text="Cancel">
                    <Publish Event="SpawnDialog" Value="CancelDlg" />
                </Control>
            </Dialog>

            <!-- AI Tools Integration dialog: four checkboxes, all pre-checked -->
            <Dialog Id="AiClientsDlg" Width="370" Height="270" Title="AI Tools Integration">
                <Control Id="BannerBitmap" Type="Bitmap" X="0" Y="0" Width="370" Height="44" TabSkip="no" Text="WixUI_Bmp_Banner" />
                <Control Id="BannerLine" Type="Line" X="0" Y="44" Width="370" Height="0" />

                <Control Id="Title" Type="Text" X="20" Y="10" Width="290" Height="14"
                         Transparent="yes" NoPrefix="yes"
                         Text="{\WixUI_Font_Title}AI Tools Integration" />

                <Control Id="Description" Type="Text" X="25" Y="55" Width="320" Height="40"
                         Transparent="yes" NoPrefix="yes"
                         Text="SaddleRAG can register itself with these AI tools so its tools and skills are available automatically in every session. VS Code uses a local Copilot plugin; the others use per-user config files. All recommended." />

                <Control Id="ChkClaudeCode" Type="CheckBox" X="25" Y="96" Width="320" Height="17"
                         Property="REGISTER_CLAUDE_CODE" CheckBoxValue="1"
                         Text="Claude Code (terminal + VSCode extension)" />
                <Control Id="ChkClaudeDesktop" Type="CheckBox" X="25" Y="114" Width="320" Height="17"
                         Property="REGISTER_CLAUDE_DESKTOP" CheckBoxValue="1"
                         Text="Claude Desktop" />
                <Control Id="ChkVsCodeMcp" Type="CheckBox" X="25" Y="132" Width="320" Height="17"
                         Property="REGISTER_VSCODE_MCP" CheckBoxValue="1"
                         Text="VSCode (Copilot Chat MCP)" />
                <Control Id="ChkCopilotCli" Type="CheckBox" X="25" Y="150" Width="320" Height="17"
                         Property="REGISTER_COPILOT_CLI" CheckBoxValue="1"
                         Text="GitHub Copilot CLI" />
                <Control Id="ChkCodex" Type="CheckBox" X="25" Y="168" Width="320" Height="17"
                         Property="REGISTER_CODEX" CheckBoxValue="1"
                         Text="OpenAI Codex CLI" />

                <Control Id="InfoText" Type="Text" X="25" Y="190" Width="320" Height="32"
                         Transparent="yes" NoPrefix="yes"
                         Text="Touches per-user integration only: %USERPROFILE%\.claude.json, %APPDATA%\Claude\claude_desktop_config.json, %APPDATA%\Code\User\settings.json plus the local VS Code SaddleRAG plugin folder, the Copilot CLI per-user config, and %USERPROFILE%\.codex\config.toml." />

                <Control Id="BottomLine" Type="Line" X="0" Y="224" Width="370" Height="0" />
                <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Text="&amp;Back">
                    <Publish Event="NewDialog" Value="ExecutionModeDlg" />
                </Control>
                <Control Id="Next" Type="PushButton" X="236" Y="243" Width="56" Height="17" Default="yes" Text="&amp;Next">
                    <Publish Event="NewDialog" Value="VerifyReadyDlg" />
                </Control>
                <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Cancel="yes" Text="Cancel">
                    <Publish Event="SpawnDialog" Value="CancelDlg" />
                </Control>
            </Dialog>

            <!-- Wire custom dialogs into the install flow -->
            <Publish Dialog="InstallDirDlg" Control="Next" Event="NewDialog" Value="MongoDbDlg" Order="5" />
            <Publish Dialog="VerifyReadyDlg" Control="Back" Event="NewDialog" Value="AiClientsDlg" Order="4" />
        </UI>

    </Package>

</Wix>
